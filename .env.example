PORT=3020
BRIDGE_USERNAME=
BRIDGE_PASSWORD=
DB_DIR=/data/whatsapp
WEBHOOK_URL=http://localhost:8000
WEBHOOK_SECRET=your-webhook-secret
DEFAULT_SESSION_ID=
LOG_LEVEL=WARN
MEDIA_TTL_SECONDS=3600
# PUBLIC_URL is the publicly reachable base URL of this bridge service.
# Used to construct media_url values in outbound webhooks.
# Set this to your externally reachable bridge URL in production.
PUBLIC_URL=https://bridge.example.com

# PostHog analytics (optional — leave blank to disable tracking)
# POSTHOG_API_KEY is the project API key from your PostHog dashboard.
POSTHOG_API_KEY=
# POSTHOG_HOST overrides the ingest endpoint (for self-hosted PostHog).
# Leave blank to use the PostHog US cloud: https://app.posthog.com
POSTHOG_HOST=
